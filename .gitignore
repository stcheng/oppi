# Server
server/node_modules/
server/dist/

# Apple client (iOS + macOS)
clients/apple/build/
clients/apple/.build/
clients/apple/docs/
clients/apple/*.xcodeproj/
# clients/apple/OppiMacTests/  # Un-ignored: Mac tests should be tracked
clients/apple/.env.testflight.local

# Scripts — only build-wired scripts are tracked
scripts/
server/scripts/*
!server/scripts/architecture-layer-rules.mjs
!server/scripts/check-architecture-boundaries.mjs
!server/scripts/check-testing-policy.mjs
!server/scripts/telemetry-review.mjs
clients/apple/scripts/
!server/docker/entrypoint.sh

# CI / internal tooling
.github/
.reviews/

# Agent
.internal/
.pi/
.claude/

# Secrets & credentials (never commit)
auth.json
*.p8
*.pem
**/identity/private*.json
**/identity/*.pem
clients/apple/Local.xcconfig

# Runtime data
session-traces/
*.log

# General
*.tsbuildinfo
*.tgz
.DS_Store
*.ips
node_modules/
server/coverage/
.ruff_cache/

# Performance artifacts (never commit)
*.tailspin.gz
.bench-output.txt

# Screen recordings (large, accidental commits)
ScreenRecording_*.mov

server/extensions/

# Autoresearch session artifacts (regenerated each run)
**/autoresearch.md
**/autoresearch.jsonl
**/autoresearch.sh
**/autoresearch.checks.sh
**/autoresearch.ideas.md
sample.org
sample.tex
sample.mmd
