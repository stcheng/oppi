{
  "version": 2,
  "gates": {
    "pr-fast": [
      "check",
      "test:coverage"
    ],
    "nightly-deep": [
      "check",
      "test:coverage",
      "test:ios:coverage",
      "test:ios:ui:full",
      "test:e2e:linux",
      "test:e2e:linux:https",
      "test:e2e:lmstudio:contract"
    ],
    "release-preflight": [
      "check",
      "test:coverage",
      "test:ios:coverage",
      "telemetry:review:gate"
    ]
  },
  "ci": {
    "prWorkflow": {
      "path": ".github/workflows/pr-fast-gate.yml",
      "command": "cd server && npm run test:gate:pr-fast"
    },
    "nightlyWorkflow": {
      "path": ".github/workflows/nightly-deep-gate.yml",
      "command": "cd server && npm run test:gate:nightly-deep"
    }
  },
  "docs": {
    "canonical": "docs/testing/README.md"
  }
}
