          "datasource": {
            "type": "frser-sqlite-datasource",
            "uid": "oppi-telemetry-sqlite"
          },
          "queryType": "table",
          "rawQueryText": "SELECT\n  metric,\n  COUNT(*) AS samples,\n  ROUND(AVG(value), 2) AS avg_value,\n  ROUND(MIN(value), 2) AS min_value,\n  ROUND(MAX(value), 2) AS max_value,\n  MAX(build_number) AS latest_build\nFROM chat_metric_samples\nWHERE ts_ms BETWEEN $__from AND $__to\nGROUP BY metric\nORDER BY samples DESC",
          "queryText": "SELECT\n  metric,\n  COUNT(*) AS samples,\n  ROUND(AVG(value), 2) AS avg_value,\n  ROUND(MIN(value), 2) AS min_value,\n  ROUND(MAX(value), 2) AS max_value,\n  MAX(build_number) AS latest_build\nFROM chat_metric_samples\nWHERE ts_ms BETWEEN $__from AND $__to\nGROUP BY metric\nORDER BY samples DESC",
          "timeColumns": [],
          "refId": "A"
